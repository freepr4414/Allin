{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flutter: Get Dependencies",
            "type": "shell",
            "command": "flutter",
            "args": [
                "pub",
                "get"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Flutter: Build Windows",
            "type": "shell",
            "command": "flutter",
            "args": [
                "build",
                "windows",
                "--release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Flutter: Get Dependencies"
        },
        {
            "label": "Flutter: Build Windows (Debug)",
            "type": "shell",
            "command": "flutter",
            "args": [
                "build",
                "windows",
                "--debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Flutter: Get Dependencies"
        },
        {
            "label": "Flutter: Build Linux",
            "type": "shell",
            "command": "flutter",
            "args": [
                "build",
                "linux",
                "--release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Flutter: Get Dependencies"
        },
        {
            "label": "Flutter: Build Android APK",
            "type": "shell",
            "command": "flutter",
            "args": [
                "build",
                "apk",
                "--release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Flutter: Get Dependencies"
        },
        {
            "label": "Flutter: Build Android Bundle",
            "type": "shell",
            "command": "flutter",
            "args": [
                "build",
                "appbundle",
                "--release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Flutter: Get Dependencies"
        },
        {
            "label": "Flutter: Build iOS",
            "type": "shell",
            "command": "flutter",
            "args": [
                "build",
                "ios",
                "--release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Flutter: Get Dependencies"
        },
        {
            "label": "Flutter: Build iOS (No Codesign)",
            "type": "shell",
            "command": "flutter",
            "args": [
                "build",
                "ios",
                "--release",
                "--no-codesign"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Flutter: Get Dependencies"
        },
        {
            "label": "Flutter: Run Windows",
            "type": "shell",
            "command": "flutter",
            "args": [
                "run",
                "-d",
                "windows"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Flutter: Get Dependencies"
        },
        {
            "label": "Flutter: Clean",
            "type": "shell",
            "command": "flutter",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Flutter: Doctor",
            "type": "shell",
            "command": "flutter",
            "args": [
                "doctor",
                "-v"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
