{
    // infree Flutter 전체 크로스 플랫폼 프로젝트 설정 (웹, 윈도우, 안드로이드, 리눅스, iOS)
    "dart.flutterSdkPath": "",
    "dart.debugExternalPackageLibraries": false,
    "dart.debugSdkLibraries": false,
    // 파일 저장 안전성 설정
    "files.autoSave": "onFocusChange",
    "files.autoSaveDelay": 1000,
    "files.hotExit": "onExitAndWindowClose",
    "workbench.editor.restoreViewState": true,
    "workbench.editor.enablePreview": false,
    "dart.openDevTools": "flutter",
    "dart.previewFlutterUiGuides": true,
    "dart.previewFlutterUiGuidesCustomTracking": true,
    // 전체 크로스 플랫폼 지원 설정
    "dart.flutterCreatePlatforms": [
        "web",
        "windows",
        "android",
        "linux",
        "ios"
    ],
    // 플랫폼별 실행 설정
    "dart.flutterRunAdditionalArgs": [
        "--web-renderer",
        "canvaskit"
    ],
    // Android 개발 설정
    "dart.flutterCreateAndroidLanguage": "kotlin",
    "dart.flutterCreateIOSLanguage": "swift",
    // 웹 개발 최적화
    "dart.flutterWebRenderer": "canvaskit",
    // 코드 포맷팅
    "dart.lineLength": 100,
    "editor.rulers": [
        100
    ],
    // 다중 플랫폼 디버깅 설정
    "dart.vmServicePort": 8181,
    "dart.flutterHotReloadOnSave": "all",
    // 파일 연결 설정
    "files.associations": {
        "*.dart": "dart",
        "pubspec.yaml": "yaml",
        "analysis_options.yaml": "yaml"
    },
    // 플랫폼별 빌드 출력 제외
    "files.exclude": {
        "**/build/": true,
        "**/.dart_tool/": true,
        "**/.packages": true,
        "**/.metadata": true,
        "**/android/.gradle/": true,
        "**/android/app/build/": true,
        "**/linux/build/": true,
        "**/windows/build/": true
    }
}